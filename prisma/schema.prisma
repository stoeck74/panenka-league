// Panenka League - Database Schema
// Documentation : https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  USER
  ADMIN
}

enum MatchdayStatus {
  UPCOMING    // pas encore commencée
  ACTIVE      // ouverte aux pronos
  FINISHED    // tous les matchs joués
}

enum MatchStatus {
  SCHEDULED   // prévu, pas encore commencé
  LIVE        // en cours
  FINISHED    // terminé
  POSTPONED   // reporté
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  username       String   @unique
  password       String
  name           String?
  avatar         String?
  avatarSeed     String?
  avatarStyle    String?
  bio            String?
  favoriteTeamId String?
  favoritePlayer String?
  role           UserRole @default(USER)
  bonusPoints    Int      @default(0)  // ajustement manuel admin (corrections de bug)
  

  // Golden Boot
  goldenBootPoints      Int     @default(0)
  
  goldenBoot1stPlayerId String?
  goldenBoot2ndPlayerId String?
  goldenBoot3rdPlayerId String?
  goldenBoot1stPlayer   Player? @relation("GoldenBoot1st", fields: [goldenBoot1stPlayerId], references: [id])
  goldenBoot2ndPlayer   Player? @relation("GoldenBoot2nd", fields: [goldenBoot2ndPlayerId], references: [id])
  goldenBoot3rdPlayer   Player? @relation("GoldenBoot3rd", fields: [goldenBoot3rdPlayerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  favoriteTeam       Team?            @relation(fields: [favoriteTeamId], references: [id])
  predictions        Prediction[]
  invitationsCreated InvitationCode[]
  accounts           Account[]
  sessions           Session[]
}

model InvitationCode {
  id          String    @id @default(cuid())
  code        String    @unique
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  usedById    String?   @unique
  usedAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

// ============================================
// SEASON & TEAM
// ============================================

model Season {
  id         String   @id @default(cuid())
  name       String
  externalId Int?     @unique
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  matchdays Matchday[]
  teams     SeasonTeam[]
  scorers   Scorer[]
}

model Team {
  id         String   @id @default(cuid())
  externalId Int      @unique
  name       String
  shortName  String
  tla        String
  crestUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  homeMatches Match[]    @relation("HomeTeam")
  awayMatches Match[]    @relation("AwayTeam")
  fans        User[]
  seasons     SeasonTeam[]
  scorers     Scorer[]
  players     Player[]
}

model SeasonTeam {
  seasonId String
  teamId   String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([seasonId, teamId])
}

// ============================================
// MATCHDAY & MATCH
// ============================================

model Matchday {
  id        String         @id @default(cuid())
  number    Int
  seasonId  String
  status    MatchdayStatus @default(UPCOMING)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relations
  season  Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  matches Match[]

  @@unique([seasonId, number])
}

model Match {
  id         String      @id @default(cuid())
  externalId Int         @unique
  matchdayId String
  homeTeamId String
  awayTeamId String
  kickoffAt  DateTime
  status     MatchStatus @default(SCHEDULED)
  homeScore  Int?
  awayScore  Int?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  // Relations
  matchday    Matchday     @relation(fields: [matchdayId], references: [id], onDelete: Cascade)
  homeTeam    Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  predictions Prediction[]
}

// ============================================
// PREDICTION
// ============================================

model Prediction {
  id           String   @id @default(cuid())
  userId       String
  matchId      String
  homeScore    Int
  awayScore    Int
  isBanco      Boolean  @default(false)
  pointsEarned Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

// ============================================
// SCORERS — Top buteurs L1 (sync depuis Football-Data)
// ============================================

model Scorer {
  id         String   @id @default(cuid())
  externalId Int      @unique
  name       String
  seasonId   String
  teamId     String
  goals      Int      @default(0)
  rank       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id])

  @@index([seasonId, rank])
}

// ============================================
// PLAYER — Joueurs L1 (pour Golden Boot)
// ============================================

model Player {
  id          String   @id @default(cuid())
  externalId  Int      @unique
  name        String
  position    String?  // "Offence" | "Midfield" | "Defence" | "Goalkeeper"
  nationality String?
  photoUrl    String?  // URL photo depuis api-football
  teamId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  team Team @relation(fields: [teamId], references: [id])

  // Relations inverses Golden Boot
  goldenBoot1stFor User[] @relation("GoldenBoot1st")
  goldenBoot2ndFor User[] @relation("GoldenBoot2nd")
  goldenBoot3rdFor User[] @relation("GoldenBoot3rd")

  @@index([teamId])
  @@index([position])
}

// ============================================
// AUTH.JS TABLES
// ============================================

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
